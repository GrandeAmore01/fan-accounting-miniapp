page {
  min-height: 100vh;
  background: #fffaf0;
  color: #252116;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
}

.page-title {
  display: block;
  margin-bottom: 12rpx;
  color: #1f1b12;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.page-subtitle {
  display: block;
  margin-bottom: 28rpx;
  color: #776f5e;
  font-size: 26rpx;
  line-height: 1.5;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #efe2ae;
  border-radius: 16rpx;
  background: #fffdf7;
  box-shadow: 0 10rpx 28rpx rgba(127, 93, 0, 0.07);
}

.card-title {
  display: block;
  margin-bottom: 14rpx;
  color: #2d2718;
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: #837965;
  font-size: 24rpx;
  line-height: 1.5;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff0b5;
  color: #8a6b00;
  font-size: 22rpx;
}

.metric {
  display: block;
  color: #b48a00;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 12rpx;
  background: #f5c400;
  color: #111111;
  font-size: 28rpx;
  line-height: 1;
  text-align: center;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  border: 1rpx solid #e8d17b;
  border-radius: 12rpx;
  background: #ffffff;
  color: #6f5600;
  font-size: 26rpx;
  line-height: 1;
  text-align: center;
}

.empty {
  padding: 44rpx 24rpx;
  border: 1rpx dashed #dbc26d;
  border-radius: 14rpx;
  color: #837965;
  text-align: center;
}
