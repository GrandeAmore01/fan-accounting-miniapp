page {
  min-height: 100vh;
  background: #f7f5f2;
  color: #2d2928;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
}

.page-title {
  display: block;
  margin-bottom: 12rpx;
  color: #221f20;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.page-subtitle {
  display: block;
  margin-bottom: 28rpx;
  color: #7a7270;
  font-size: 26rpx;
  line-height: 1.5;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #eee2dc;
  border-radius: 16rpx;
  background: #fffaf7;
  box-shadow: 0 10rpx 28rpx rgba(62, 45, 41, 0.06);
}

.card-title {
  display: block;
  margin-bottom: 14rpx;
  color: #332c2b;
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: #877d7a;
  font-size: 24rpx;
  line-height: 1.5;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f2e2df;
  color: #9d3f57;
  font-size: 22rpx;
}

.metric {
  display: block;
  color: #c84d69;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.primary-button {
  height: 76rpx;
  border-radius: 12rpx;
  background: #c84d69;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 76rpx;
}

.secondary-button {
  height: 68rpx;
  border: 1rpx solid #ead4ce;
  border-radius: 12rpx;
  background: #ffffff;
  color: #9d3f57;
  font-size: 26rpx;
  line-height: 66rpx;
}

.empty {
  padding: 44rpx 24rpx;
  border: 1rpx dashed #dfcac3;
  border-radius: 14rpx;
  color: #877d7a;
  text-align: center;
}
