<view class="page">
  <text class="page-title">藏品图鉴</text>
  <text class="page-subtitle">公共资料与点亮状态均同步自云端。</text>

  <view class="card progress-card">
    <view class="row">
      <text>已拥有 {{progress.ownedCount}} / {{progress.total}}</text>
      <text class="percent">{{progress.percent}}%</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progress.percent}}%;"></view>
    </view>
  </view>

  <view class="toolbar card">
    <input class="search-input" value="{{keyword}}" placeholder="搜索藏品名称或所属系列" bindinput="handleKeywordInput" />
    <view class="category-section">
      <text class="filter-label">一级分类</text>
      <view class="chip-wrap">
        <view wx:for="{{primaryTabs}}" wx:key="name" class="filter-chip {{item.active ? 'active' : ''}}" data-index="{{index}}" bindtap="handlePrimaryTap">
          <text>{{item.name}}</text>
          <text class="chip-count">（{{item.count}}件）</text>
        </view>
      </view>
    </view>
    <view class="category-section">
      <text class="filter-label">二级分类</text>
      <view class="chip-wrap">
        <view wx:for="{{secondaryTabs}}" wx:key="name" class="filter-chip {{item.active ? 'active' : ''}}" data-index="{{index}}" bindtap="handleSecondaryTap">
          <text>{{item.name}}</text>
          <text class="chip-count">（{{item.count}}件）</text>
        </view>
      </view>
    </view>
    <view class="filter-grid">
      <picker range="{{styleOptions}}" value="{{styleIndex}}" bindchange="handleStyleChange">
        <view class="picker-field">款式：{{styleOptions[styleIndex]}}</view>
      </picker>
      <picker range="{{statusOptions}}" value="{{statusIndex}}" bindchange="handleStatusChange">
        <view class="picker-field">状态：{{statusOptions[statusIndex]}}</view>
      </picker>
    </view>
    <view class="filter-actions">
      <button class="primary-button compact-button" bindtap="handleConfirmFilter">确定查询</button>
      <button class="secondary-button compact-button" bindtap="handleClearFilter">一键重置</button>
    </view>
  </view>

  <view class="card state-card" wx:if="{{loading}}">正在加载藏品图鉴…</view>
  <view class="card state-card" wx:elif="{{loadError}}">
    <text>{{loadError}}</text>
    <button class="secondary-button" bindtap="loadCollections">重新加载</button>
  </view>
  <view class="card state-card" wx:elif="{{visibleCollections.length === 0}}">
    <text>暂无符合条件的藏品</text>
    <button class="secondary-button" bindtap="handleClearFilter">重置筛选</button>
  </view>

  <block wx:if="{{!loading && !loadError && visibleCollections.length > 0}}">
    <view class="result-summary">{{resultSummary.text}}</view>
    <view class="collection-grid">
      <view class="collection-item {{item.isOwned ? 'owned' : 'missing'}}" wx:for="{{visibleCollections}}" wx:key="collectionId" data-id="{{item.collectionId}}" bindtap="handleCollectionTap">
        <view class="image-box">
          <image wx:if="{{item.imageUrl && !item.imageFailed}}" class="collection-image" src="{{item.imageUrl}}" mode="aspectFill" data-id="{{item.collectionId}}" binderror="handleImageError" />
          <view wx:else class="image-placeholder">
            <text>暂无图片</text>
          </view>
          <text class="owned-badge" wx:if="{{item.isOwned}}">已拥有</text>
        </view>
        <view class="name-box {{item.isLongName ? 'name-marquee' : ''}}">
          <view wx:if="{{item.isLongName}}" class="marquee-track" style="animation-duration: {{item.marqueeDuration}}s;">
            <text class="item-name marquee-copy">{{item.collectionName}}</text>
            <text class="item-name marquee-copy">{{item.collectionName}}</text>
          </view>
          <text wx:else class="item-name">{{item.collectionName}}</text>
        </view>
        <text class="item-date">{{item.saleDateText || '日期待补充'}}</text>
        <text class="style-tag">{{item.productStyle}}</text>
      </view>
    </view>
    <view class="load-more-wrap">
      <button wx:if="{{hasMoreCollections}}" class="secondary-button load-more-button" bindtap="handleLoadMore">加载更多</button>
      <text wx:else class="no-more-text">已全部展示</text>
    </view>
  </block>

  <view wx:if="{{detailVisible && selectedCollection}}" class="detail-mask" bindtap="closeCollectionDetail">
    <view class="detail-panel" catchtap="stopDetailTap">
      <view class="detail-image-wrap">
        <image wx:if="{{selectedCollection.imageUrl && !selectedCollection.imageFailed}}" class="detail-image" src="{{selectedCollection.imageUrl}}" mode="aspectFit" data-id="{{selectedCollection.collectionId}}" binderror="handleImageError" />
        <view wx:else class="detail-image-placeholder">暂无图片</view>
        <text class="detail-owned-badge" wx:if="{{selectedCollection.isOwned}}">已拥有</text>
      </view>
      <view class="detail-body">
        <text class="detail-title">{{selectedCollection.collectionName}}</text>
        <view class="detail-row" wx:if="{{selectedCollection.seriesName}}">
          <text class="detail-label">所属系列</text>
          <text class="detail-value">{{selectedCollection.seriesName}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">分类</text>
          <text class="detail-value">{{selectedCollection.primaryCategory}} / {{selectedCollection.secondaryCategory}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">款式</text>
          <text class="detail-value">{{selectedCollection.productStyle}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">售卖日期</text>
          <text class="detail-value">{{selectedCollection.saleDateText || '日期待补充'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">价格</text>
          <text class="detail-value">{{selectedCollection.priceText || '暂无参考价'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">状态</text>
          <text class="detail-value">{{selectedCollection.isOwned ? '已拥有' : '未点亮'}}</text>
        </view>
      </view>
      <view class="detail-actions">
        <button class="secondary-button detail-button" bindtap="closeCollectionDetail">关闭</button>
        <button class="primary-button detail-button" loading="{{busyCollectionId === selectedCollection.collectionId}}" bindtap="handleDetailPrimaryAction">{{selectedCollection.isOwned ? '取消点亮' : '点亮藏品'}}</button>
      </view>
    </view>
  </view>
</view>
