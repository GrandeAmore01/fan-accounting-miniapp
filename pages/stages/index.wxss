.card .muted {
  display: block;
  margin-top: 10rpx;
}

.card button {
  margin-top: 20rpx;
}

.progress-track,
.mini-track {
  height: 20rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f4e6a8;
}

.progress-fill,
.mini-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #f5c400;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.segment {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 6rpx;
  border-radius: 14rpx;
  background: #fff0b5;
}

.segment-item {
  min-height: 64rpx;
  border-radius: 10rpx;
  color: #776f5e;
  font-size: 25rpx;
  line-height: 64rpx;
  text-align: center;
}

.segment-active {
  background: #ffffff;
  color: #b48a00;
  font-weight: 700;
  box-shadow: 0 4rpx 14rpx rgba(127, 93, 0, 0.09);
}

.search-input,
.picker-field {
  width: 100%;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e8d17b;
  border-radius: 12rpx;
  background: #ffffff;
  color: #252116;
  font-size: 26rpx;
  line-height: 72rpx;
}

.filter-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.compact-button {
  height: 64rpx;
  margin: 0;
  font-size: 25rpx;
  line-height: 64rpx;
}

.info-row {
  margin-top: 6rpx;
}

.lighted-text,
.unlighted-text {
  font-size: 25rpx;
  font-weight: 600;
}

.lighted-text {
  color: #4d8160;
}

.unlighted-text {
  color: #837965;
}

.song-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f4e6a8;
}

.song-item:last-child {
  border-bottom: 0;
}

.song-name {
  color: #2d2718;
  font-size: 27rpx;
  font-weight: 600;
}

.album-item {
  margin-top: 24rpx;
}

.mini-track {
  height: 16rpx;
  margin-top: 12rpx;
}
