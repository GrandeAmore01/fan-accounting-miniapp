.card .muted {
  display: block;
  margin-top: 10rpx;
}

.card button {
  margin-top: 20rpx;
}

.progress-track,
.mini-track {
  height: 20rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f0e4df;
}

.progress-fill,
.mini-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #c84d69;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.search-input,
.picker-field {
  width: 100%;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #eadbd5;
  border-radius: 12rpx;
  background: #ffffff;
  color: #2d2928;
  font-size: 26rpx;
  line-height: 72rpx;
}

.filter-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.compact-button {
  height: 64rpx;
  margin: 0;
  font-size: 25rpx;
  line-height: 64rpx;
}

.info-row {
  margin-top: 6rpx;
}

.lighted-text,
.unlighted-text {
  font-size: 25rpx;
  font-weight: 600;
}

.lighted-text {
  color: #4d8160;
}

.unlighted-text {
  color: #877d7a;
}

.song-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0e4df;
}

.song-item:last-child {
  border-bottom: 0;
}

.song-name {
  color: #3c3533;
  font-size: 27rpx;
  font-weight: 600;
}

.album-item {
  margin-top: 24rpx;
}

.mini-track {
  height: 16rpx;
  margin-top: 12rpx;
}
