<view class="page profile-page">
  <text class="page-title">我的</text>
  <text class="page-subtitle">记录每一次喜欢，也照顾好自己的预算。</text>

  <view class="profile-hero">
    <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar" disabled="{{savingProfile}}">
      <image wx:if="{{profile.avatarUrl}}" class="avatar-image" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">微</view>
      <view class="avatar-edit-badge">编辑</view>
    </button>
    <view class="profile-main">
      <view class="profile-name-row" bindtap="handleEditNickname">
        <text class="profile-name">{{profile.nickname || '微信用户'}}</text>
        <text class="profile-edit">编辑</text>
      </view>
      <view class="profile-sync-line">
        <view class="sync-dot {{sync.state}}"></view>
        <text>{{sync.label}}</text>
        <text wx:if="{{sync.lastTime}}" class="sync-time">{{sync.lastTime}}</text>
      </view>
      <text class="profile-slogan">头像和昵称由你设置，不会修改微信资料</text>
    </view>
  </view>

  <view class="card overview-card">
    <view class="section-header">
      <text class="card-title">我的数据</text>
      <text class="section-hint">点击查看详情</text>
    </view>
    <view class="overview-grid">
      <view class="overview-item" bindtap="handleNavigate" data-url="/pages/expenses/index">
        <text class="overview-value">{{overview.expenseCount}}</text>
        <text class="overview-label">消费记录</text>
      </view>
      <view class="overview-item" bindtap="handleNavigate" data-url="/pages/expenses/index">
        <text class="overview-value money-value">¥{{overview.totalAmountText}}</text>
        <text class="overview-label">累计支出</text>
      </view>
      <view class="overview-item" bindtap="handleNavigate" data-url="/pages/collections/index">
        <text class="overview-value">{{overview.collectionCount}}</text>
        <text class="overview-label">点亮藏品</text>
      </view>
      <view class="overview-item" bindtap="handleNavigate" data-url="/pages/stages/index">
        <text class="overview-value">{{overview.stageCount}}</text>
        <text class="overview-label">点亮舞台</text>
      </view>
    </view>
  </view>

  <view class="card budget-card" bindtap="handleNavigate" data-url="/pages/budget/index">
    <view class="section-header">
      <text class="card-title">本月预算</text>
      <text class="chevron">›</text>
    </view>
    <block wx:if="{{budget.hasBudget}}">
      <view class="budget-amount-row">
        <view>
          <text class="budget-caption">剩余预算</text>
          <text class="budget-remaining">¥{{budget.remainingAmountText}}</text>
        </view>
        <text class="budget-ratio">¥{{budget.usedAmountText}} / ¥{{budget.amountText}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill {{budget.percent > 100 ? 'over' : ''}}" style="width: {{budget.progressWidth}}%;"></view>
      </view>
      <text class="budget-status">{{budget.statusText}}</text>
    </block>
    <view wx:else class="budget-empty">
      <text>还没有设置本月预算</text>
      <text class="budget-empty-action">去设置 ›</text>
    </view>
  </view>

  <view class="card settings-card">
    <view class="setting-row" bindtap="handleSyncTap">
      <view class="setting-main">
        <text class="setting-title">云端同步</text>
        <text class="setting-desc">{{sync.message}}</text>
      </view>
      <view class="setting-state {{sync.state}}">{{sync.label}}</view>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-row" bindtap="handlePrivacyTap">
      <view class="setting-main">
        <text class="setting-title">数据与隐私</text>
        <text class="setting-desc">了解数据保存与使用方式</text>
      </view>
      <text class="chevron">›</text>
    </view>
    <view class="setting-divider"></view>
    <view class="setting-row" bindtap="handleClearLocalData">
      <view class="setting-main">
        <text class="setting-title">清理本机缓存</text>
        <text class="setting-desc">不会删除云端数据</text>
      </view>
      <text class="chevron">›</text>
    </view>
  </view>

  <view class="privacy-note">
    <text class="privacy-title">隐私优先</text>
    <text>你的个人记录不会公开展示，也不会用于粉丝消费排名。</text>
  </view>
</view>
