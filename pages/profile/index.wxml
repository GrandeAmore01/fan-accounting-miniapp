<view class="page">
  <text class="page-title">我的</text>
  <text class="page-subtitle">账号、云端同步与本地缓存管理。</text>

  <view class="card profile-card">
    <view class="avatar-placeholder">微</view>
    <view class="profile-main">
      <text class="card-title">{{profile.nickname}}</text>
      <text class="muted">登录状态：{{cloudStatus.loginReady ? '微信身份已连接' : '正在连接微信身份'}}</text>
      <text class="tag">数据按微信用户安全隔离</text>
    </view>
  </view>

  <view class="card">
    <view class="row">
      <text class="card-title">云端同步</text>
      <text class="{{cloudStatus.loginReady ? 'status-on' : 'status-off'}}">
        {{cloudStatus.loginReady ? '已连接' : '连接中'}}
      </text>
    </view>
    <text class="muted">{{cloudStatus.message}}</text>
    <button class="secondary-button" bindtap="handleCloudStatusTap">查看同步状态</button>
  </view>

  <view class="card">
    <view class="row">
      <text class="card-title">本机缓存概览</text>
      <text class="{{hasLocalData ? 'status-on' : 'status-off'}}">{{hasLocalData ? '已有缓存' : '暂无缓存'}}</text>
    </view>
    <view class="data-grid">
      <view class="data-cell"><text class="metric">{{counts.expenses}}</text><text class="muted">消费缓存</text></view>
      <view class="data-cell"><text class="metric">{{counts.budgets}}</text><text class="muted">预算缓存</text></view>
      <view class="data-cell"><text class="metric">{{counts.lightedCollections}}/{{counts.userCollections}}</text><text class="muted">藏品缓存</text></view>
      <view class="data-cell"><text class="metric">{{counts.lightedStages}}/{{counts.userStages}}</text><text class="muted">舞台缓存</text></view>
    </view>
    <button class="secondary-button danger-button" bindtap="handleClearLocalData">清理本机缓存</button>
  </view>

  <view class="card">
    <text class="card-title">隐私与同步</text>
    <text class="muted">消费、预算、藏品点亮和舞台记录以云端数据为准，可在不同设备间同步。</text>
    <text class="muted">本地只保留最近一次成功数据、临时草稿和页面状态，用于加速显示。</text>
    <text class="muted">清理本地缓存不会删除云端数据。</text>
  </view>
</view>
