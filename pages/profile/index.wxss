.card .muted {
  display: block;
  margin-top: 10rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #c84d69;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-main .tag {
  margin-top: 12rpx;
}

.status-on,
.status-off {
  font-size: 24rpx;
  font-weight: 600;
}

.status-on {
  color: #4d8160;
}

.status-off {
  color: #877d7a;
}

.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 18rpx;
}

.data-cell {
  min-height: 132rpx;
  padding: 22rpx;
  border: 1rpx solid #eadbd5;
  border-radius: 14rpx;
  background: #ffffff;
}

.card button {
  margin-top: 18rpx;
}

.danger-button {
  color: #a13f3f;
}
