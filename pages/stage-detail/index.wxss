.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.link-text {
  color: #b48a00;
  font-size: 26rpx;
  font-weight: 700;
}

.info-line {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
  color: #2d2718;
  font-size: 26rpx;
  line-height: 1.6;
}

.info-label {
  flex-shrink: 0;
  width: 140rpx;
  color: #837965;
}

.status-text {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.lighted-text {
  color: #4d8160;
}

.unlighted-text {
  color: #837965;
}

.field-input,
.field-textarea {
  width: 100%;
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #e8d17b;
  border-radius: 12rpx;
  background: #ffffff;
  color: #252116;
  font-size: 26rpx;
}

.field-textarea {
  min-height: 160rpx;
}

.song-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.song-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0b5;
  color: #6f5600;
  font-size: 24rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item,
.photo-add {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background: #fff7da;
}

.photo-add {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #dbc26d;
  color: #b48a00;
  font-size: 56rpx;
}

.photo-tip {
  display: block;
  margin-top: 12rpx;
}

.card .primary-button {
  margin-top: 20rpx;
}
