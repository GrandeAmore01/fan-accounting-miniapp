<view class="page">
  <text class="page-title">消费记录</text>
  <text class="page-subtitle">按见面、实体专辑、周边和商务记录消费，也可以保存图片作为追星回忆。</text>

  <view class="card">
    <view class="row">
      <view>
        <text class="muted">累计消费</text>
        <text class="metric">￥{{summary.totalAmount}}</text>
      </view>
      <view>
        <text class="muted">记录数</text>
        <text class="metric">{{summary.count}}</text>
      </view>
    </view>
    <text class="muted">预算使用进度：{{budgetProgress.percent}}%</text>
  </view>

  <view class="toolbar card">
    <input class="search-input" value="{{keyword}}" placeholder="搜索项目或备注" bindinput="handleKeywordInput" />
    <picker mode="selector" range="{{filterCategories}}" range-key="name" value="{{filterCategoryIndex}}" bindchange="handleFilterCategoryChange">
      <view class="picker-field">{{filterCategories[filterCategoryIndex].name}}</view>
    </picker>
    <view class="toolbar-actions">
      <button class="secondary-button compact-button" bindtap="handleClearFilter">重置</button>
      <button class="primary-button compact-button" bindtap="handleOpenCreate">新增</button>
    </view>
  </view>

  <view class="card" wx:if="{{expenses.length === 0}}">
    <view class="empty">暂无符合条件的消费记录。</view>
  </view>

  <view class="card expense-card" wx:for="{{expenses}}" wx:key="expenseId">
    <view class="row">
      <text class="card-title">{{item.itemName}}</text>
      <text class="tag">{{item.categoryName}}</text>
    </view>
    <view class="row expense-meta">
      <text class="amount">￥{{item.includedAmount}}</text>
      <text class="muted">{{item.date}}</text>
    </view>
    <text class="muted">实际合计：￥{{item.totalAmount}} · 基础金额：￥{{item.amount}} · 数量：{{item.quantity}}</text>
    <text class="muted">统计口径：{{item.includeInTotal ? '计入总消费' : '不计入总消费'}} · 计入统计：￥{{item.includedAmount}}</text>
    <text class="muted" wx:if="{{item.images.length}}">图片：{{item.images.length}} 张</text>
    <text class="muted" wx:if="{{item.stageId}}">已联动舞台：{{item.stageId}}</text>
    <text class="muted" wx:if="{{item.remark}}">备注：{{item.remark}}</text>
    <view class="item-actions">
      <button class="secondary-button compact-button" data-id="{{item.expenseId}}" bindtap="handleOpenEdit">编辑</button>
      <button class="secondary-button compact-button danger-button" data-id="{{item.expenseId}}" bindtap="handleDeleteExpense">删除</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{formVisible}}" catchtap="handleCloseForm">
    <view class="modal-panel" catchtap="noop">
      <view class="row modal-header">
        <text class="card-title">{{formTitle}}</text>
        <button class="close-button" bindtap="handleCloseForm">×</button>
      </view>

      <view class="field-grid">
        <view class="form-field">
          <text class="field-label">大类型</text>
          <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="handleCategoryChange">
            <view class="picker-field">{{categories[categoryIndex].name}}</view>
          </picker>
        </view>
        <view class="form-field">
          <text class="field-label">小类型</text>
          <picker mode="selector" range="{{subTypes}}" range-key="name" value="{{subTypeIndex}}" bindchange="handleSubTypeChange">
            <view class="picker-field">{{subTypes[subTypeIndex].name}}</view>
          </picker>
        </view>
      </view>

      <view class="field-grid">
        <view class="form-field">
          <text class="field-label">消费日期</text>
          <picker mode="date" value="{{formData.date}}" bindchange="handleDateChange">
            <view class="picker-field">{{formData.date || '请选择日期'}}</view>
          </picker>
        </view>
        <view class="form-field">
          <text class="field-label">支付方式</text>
          <picker mode="selector" range="{{paymentMethods}}" value="{{paymentMethodIndex}}" bindchange="handlePaymentMethodChange">
            <view class="picker-field">{{paymentMethods[paymentMethodIndex]}}</view>
          </picker>
        </view>
      </view>

      <view wx:if="{{formData.category === 'meet' && (formData.subType === 'concert' || formData.subType === 'festival')}}" class="form-section">
        <text class="section-title">{{formData.subType === 'concert' ? '演唱会场次' : '音乐节|拼盘场次'}}</text>
        <text class="muted">先选择消费日期，系统会按日期自动匹配具体场次。</text>
        <view class="matched-stage {{matchedMeetStageName ? '' : 'unmatched-stage'}}">
          {{matchedMeetStageName || '当前日期暂无匹配场次'}}
        </view>
        <view class="form-field" wx:if="{{!matchedMeetStageName}}">
          <text class="field-label">{{formData.subType === 'concert' ? '演唱会名称' : '音乐节|拼盘名称'}}</text>
          <input class="form-input" value="{{formData.itemName}}" data-field="itemName" placeholder="可手动填写名称" bindinput="handleFormInput" />
        </view>
        <view class="form-field">
          <text class="field-label">金额档位</text>
          <picker mode="selector" range="{{priceTierLabels}}" value="{{priceTierIndex}}" bindchange="handlePriceTierChange">
            <view class="picker-field">{{priceTierLabels.length ? priceTierLabels[priceTierIndex] : '暂无档位'}}</view>
          </picker>
        </view>
        <view class="form-field">
          <text class="field-label">金额</text>
          <input class="form-input" type="digit" value="{{formData.amount}}" data-field="amount" placeholder="可在预设档位基础上手动调整" bindinput="handleFormInput" />
        </view>
      </view>

      <view wx:elif="{{formData.category === 'goods' || formData.category === 'business'}}" class="form-section">
        <text class="section-title">{{formData.category === 'goods' ? '周边/杂志名称' : '商务品牌名称'}}</text>
        <input class="form-input" value="{{searchKeyword}}" placeholder="搜索周边/杂志名称（不受子类型限制）" bindinput="handleItemSearchInput" />
        <view class="search-result" wx:for="{{searchResults}}" wx:key="id" data-id="{{item.id}}" bindtap="handleSelectSearchItem">
          <text>{{item.name}}</text>
        </view>
        <view class="form-field">
          <text class="field-label">项目名称</text>
          <input class="form-input" value="{{formData.itemName}}" data-field="itemName" placeholder="也可手动填写名称" bindinput="handleFormInput" />
        </view>
      </view>

      <view wx:else class="form-field">
        <text class="field-label">项目名称</text>
        <input class="form-input" value="{{formData.itemName}}" data-field="itemName" placeholder="例如：实体专辑名称或活动名称" bindinput="handleFormInput" />
      </view>

      <view class="field-grid" wx:if="{{!(formData.category === 'meet' && (formData.subType === 'concert' || formData.subType === 'festival'))}}">
        <view class="form-field">
          <text class="field-label">金额</text>
          <input class="form-input" type="digit" value="{{formData.amount}}" data-field="amount" placeholder="0.00" bindinput="handleFormInput" />
        </view>
        <view class="form-field">
          <text class="field-label">数量</text>
          <input class="form-input" type="number" value="{{formData.quantity}}" data-field="quantity" placeholder="1" bindinput="handleFormInput" />
        </view>
      </view>
      <view class="form-field" wx:else>
        <text class="field-label">数量</text>
        <input class="form-input" type="number" value="{{formData.quantity}}" data-field="quantity" placeholder="1" bindinput="handleFormInput" />
      </view>

      <view wx:if="{{formData.category === 'meet' && formData.subType === 'concert'}}" class="form-section">
        <text class="section-title">附加费用</text>
        <view class="field-grid">
          <view class="form-field">
            <text class="field-label">加价</text>
            <input class="form-input" type="digit" value="{{formData.fees.premium}}" data-field="premium" placeholder="0.00" bindinput="handleFeeInput" />
          </view>
          <view class="form-field">
            <text class="field-label">路费</text>
            <input class="form-input" type="digit" value="{{formData.fees.travel}}" data-field="travel" placeholder="0.00" bindinput="handleFeeInput" />
          </view>
          <view class="form-field">
            <text class="field-label">住宿费</text>
            <input class="form-input" type="digit" value="{{formData.fees.hotel}}" data-field="hotel" placeholder="0.00" bindinput="handleFeeInput" />
          </view>
          <view class="form-field">
            <text class="field-label">设备租赁费</text>
            <input class="form-input" type="digit" value="{{formData.fees.rental}}" data-field="rental" placeholder="0.00" bindinput="handleFeeInput" />
          </view>
        </view>
        <view class="form-field fee-single">
          <text class="field-label">其他费用</text>
          <input class="form-input" type="digit" value="{{formData.fees.other}}" data-field="other" placeholder="0.00" bindinput="handleFeeInput" />
        </view>
        <view class="switch-row">
          <view>
            <text class="field-label">场外记录（不计入消费）</text>
            <text class="muted">打开后整条记录不参与预算和总消费。</text>
          </view>
          <switch checked="{{formData.outfieldOnly}}" color="#c84d69" bindchange="handleOutfieldChange" />
        </view>
      </view>

      <view wx:if="{{formData.category === 'album'}}" class="form-section">
        <text class="section-title">实体专辑补充</text>
        <view class="field-grid">
          <view class="form-field">
            <text class="field-label">加价</text>
            <input class="form-input" type="digit" value="{{formData.fees.premium}}" data-field="premium" placeholder="0.00" bindinput="handleFeeInput" />
          </view>
          <view class="form-field">
            <text class="field-label">邮费</text>
            <input class="form-input" type="digit" value="{{formData.fees.shipping}}" data-field="shipping" placeholder="0.00" bindinput="handleFeeInput" />
          </view>
        </view>
        <view class="switch-row">
          <view>
            <text class="field-label">不计入总消费</text>
            <text class="muted">例如只想记录购买渠道或票务来源时可打开。</text>
          </view>
          <switch checked="{{formData.outfieldOnly}}" color="#c84d69" bindchange="handleOutfieldChange" />
        </view>
      </view>

      <view class="form-field">
        <text class="field-label">备注</text>
        <input class="form-input" value="{{formData.remark}}" data-field="remark" placeholder="选填，例如购买渠道、票务来源、追星感受" bindinput="handleFormInput" />
      </view>

      <view class="form-section">
        <view class="row">
          <text class="section-title">图片回忆</text>
          <text class="muted">{{formData.images.length}}/9</text>
        </view>
        <view class="image-grid">
          <view class="image-item" wx:for="{{formData.images}}" wx:key="*this">
            <image src="{{item}}" mode="aspectFill"></image>
            <text class="image-remove" data-index="{{index}}" bindtap="handleRemoveImage">×</text>
          </view>
          <view class="image-add" wx:if="{{formData.images.length < 9}}" bindtap="handleChooseImages">+</view>
        </view>
      </view>

      <view wx:if="{{!(formData.category === 'meet' && formData.subType === 'concert') && formData.category !== 'album'}}" class="switch-row">
        <view>
          <text class="field-label">计入总消费统计</text>
          <text class="muted">关闭后不参与预算和累计消费。</text>
        </view>
        <switch checked="{{formData.includeInTotal}}" color="#c84d69" bindchange="handleIncludeChange" />
      </view>

      <view class="modal-actions">
        <button class="secondary-button" bindtap="handleCloseForm">取消</button>
        <button class="primary-button" bindtap="handleSubmitForm">保存</button>
      </view>
    </view>
  </view>
</view>
