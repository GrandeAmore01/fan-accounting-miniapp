<view class="page expense-page">
  <view class="expense-hero">
    <text class="hero-title">消费记录</text>
    <text class="hero-subtitle">按见面、藏品、住宿、交通和其他整理每一笔消费</text>
  </view>

  <scroll-view class="category-tabs" scroll-x="true" enable-flex="true">
    <view
      class="category-tab {{activeCategoryIndex === index ? 'category-tab-active' : ''}}"
      wx:for="{{categoryTabs}}"
      wx:key="id"
      data-index="{{index}}"
      bindtap="handleCategoryTabChange"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <view class="stats-card">
    <view class="amount-summary">
      <text class="amount-summary-label">{{activeSummary.name}}</text>
      <view class="amount-summary-value">
        <text class="amount-symbol">¥</text>
        <text class="amount-number">{{activeSummary.amountText}}</text>
      </view>
    </view>
    <view class="count-summary-grid">
      <view
        class="stat-item {{activeCategoryIndex === index ? 'stat-item-active' : ''}}"
        wx:for="{{categoryStats}}"
        wx:key="id"
        data-index="{{index}}"
        bindtap="handleCategoryTabChange"
      >
        <text class="stat-value">{{item.count}}</text>
        <text class="stat-label">{{item.name}}</text>
      </view>
    </view>
  </view>
  <view class="summary-hint">实际支出 ¥{{activeSummary.actualAmountText}}</view>

  <view class="filter-card">
    <view class="filter-row">
      <view class="filter-chip" bindtap="handleClearFilter">
        <text class="filter-chip-label">筛选</text>
        <text class="filter-chip-value">{{categoryTabs[activeCategoryIndex].name}}</text>
      </view>
      <picker mode="selector" range="{{sortOptions}}" range-key="name" value="{{sortIndex}}" bindchange="handleSortChange">
        <view class="sort-picker">{{sortOptions[sortIndex].name}}</view>
      </picker>
    </view>
    <view class="filter-switch-row">
      <view class="extra-switch">
        <text>列表显示实际金额</text>
        <switch checked="{{showActualAmount}}" color="#D6A400" bindchange="handleShowActualAmountChange" />
      </view>
      <view class="extra-switch" wx:if="{{categoryTabs[activeCategoryIndex].id === 'all'}}">
        <text>合并见面相关</text>
        <switch checked="{{mergeMeetRelatedInAll}}" color="#D6A400" bindchange="handleMergeMeetRelatedChange" />
      </view>
    </view>
    <input class="search-input" value="{{keyword}}" placeholder="搜索名称 / 地点 / 备注 / 日期" bindinput="handleKeywordInput" />
  </view>

  <button class="add-expense-button" bindtap="handleOpenCreate">添加消费记录</button>
  <text class="page-title">消费记录</text>
  <text class="page-subtitle">按见面、藏品、住宿、交通和其他记录消费，也可以保存图片作为追星回忆。</text>

  <view class="card legacy-top-card">
    <view class="row">
      <view>
        <text class="muted">累计消费</text>
        <text class="metric">￥{{summary.totalAmount}}</text>
      </view>
      <view>
        <text class="muted">记录数</text>
        <text class="metric">{{summary.count}}</text>
      </view>
    </view>
    <text class="muted">预算使用进度：{{budgetProgress.percent}}%</text>
  </view>

  <view class="toolbar card legacy-toolbar">
    <input class="search-input" value="{{keyword}}" placeholder="搜索项目或备注" bindinput="handleKeywordInput" />
    <picker mode="selector" range="{{filterCategories}}" range-key="name" value="{{filterCategoryIndex}}" bindchange="handleFilterCategoryChange">
      <view class="picker-field">{{filterCategories[filterCategoryIndex].name}}</view>
    </picker>
    <view class="toolbar-actions">
      <button class="secondary-button compact-button" bindtap="handleClearFilter">重置</button>
      <button class="primary-button compact-button" bindtap="handleOpenCreate">新增</button>
    </view>
  </view>

  <view class="card" wx:if="{{expenses.length === 0}}">
    <view class="empty">暂无符合条件的消费记录。</view>
  </view>

  <view class="card expense-card" wx:for="{{expenses}}" wx:key="expenseId">
    <view class="expense-card-new">
      <view class="expense-card-header">
        <text class="type-tag">{{item.categoryName}}</text>
        <text class="bundle-tag" wx:if="{{item.isCombinedBundle}}">已合并</text>
        <view class="amount-stack">
          <text class="display-amount">{{item.displayAmountLabel}} ¥{{item.displayAmountText}}</text>
        </view>
      </view>
      <text class="expense-title">{{item.itemName}}</text>
      <text class="expense-meta-new">{{item.metaText}}</text>
      <view class="bundle-link-row" wx:if="{{item.hasMeetBundleLink && !item.isCombinedBundle}}">
        <text class="bundle-link-note" wx:for="{{item.bundleLinkTags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="fee-tags" wx:if="{{item.feeTags.length}}">
        <text class="fee-tag" wx:for="{{item.feeTags}}" wx:for-item="fee" wx:key="key">{{fee.label}} ¥{{fee.amountText}}</text>
      </view>
      <view class="remark-tag-row" wx:if="{{item.remarkTags.length}}">
        <text class="remark-tag" wx:for="{{item.remarkTags}}" wx:for-item="tag" wx:key="*this">#{{tag}}</text>
      </view>
      <view class="expense-note-wrap" wx:if="{{item.remarkDisplayText}}">
        <text class="expense-note" wx:if="{{item.remarkDisplayText}}">{{item.remarkDisplayText}}</text>
        <text
          wx:if="{{item.remarkCanExpand && item.remarkDisplayText}}"
          class="remark-toggle"
          data-id="{{item.expenseId}}"
          bindtap="handleToggleRemark"
        >{{item.remarkExpanded ? '收起' : '展开'}}</text>
      </view>
      <text class="expense-note" wx:if="{{!item.includeInTotal}}">不计入总消费</text>
      <view class="expense-actions-new">
        <button class="edit-button compact-button" data-id="{{item.expenseId}}" bindtap="handleOpenEdit">编辑</button>
        <button class="delete-button compact-button" data-id="{{item.expenseId}}" bindtap="handleDeleteExpense">删除</button>
      </view>
    </view>
    <view class="row">
      <text class="card-title">{{item.itemName}}</text>
      <text class="tag">{{item.categoryName}}</text>
    </view>
    <view class="row expense-meta">
      <text class="amount">￥{{item.includedAmount}}</text>
      <text class="muted">{{item.date}}</text>
    </view>
    <text class="muted">实际合计：￥{{item.totalAmount}} · 门票/基础：￥{{item.baseAmount}}</text>
    <text class="muted">计入口径：{{item.includeInTotal ? '计入总消费' : '不计入总消费'}} · 计入统计：￥{{item.includedAmount}}</text>
    <text class="muted" wx:if="{{item.location || item.seat}}">地点：{{item.location || '未填写'}} · 座位：{{item.seat || '未填写'}}</text>
    <text class="muted" wx:if="{{item.stageId}}">已联动舞台：{{item.stageId}}</text>
    <text class="muted" wx:if="{{item.remark}}">备注：{{item.remarkDisplayText}}</text>
    <view class="item-actions">
      <button class="secondary-button compact-button" data-id="{{item.expenseId}}" bindtap="handleOpenEdit">编辑</button>
      <button class="secondary-button compact-button danger-button" data-id="{{item.expenseId}}" bindtap="handleDeleteExpense">删除</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{deleteConfirmVisible}}" catchtap="handleCancelDelete" catchtouchmove="noop">
    <view class="delete-dialog" catchtap="noop">
      <view class="delete-dialog-header">
        <text class="card-title">删除消费记录</text>
      </view>
      <view class="delete-dialog-body">
        <text class="delete-warning">删除后无法恢复，确定要删除吗？</text>
        <text class="delete-target" wx:if="{{deleteCurrentExpense}}">当前删除：{{deleteCurrentExpense.itemName}}</text>
        <view class="delete-linked-box" wx:if="{{deleteLinkedItems.length}}">
          <label class="delete-check-row">
            <checkbox value="linked" checked="{{deleteWithLinked}}" color="#d6a400" bindchange="handleDeleteLinkedToggle" />
            <text>同步删除关联的{{deleteLinkedText}}消费记录</text>
          </label>
          <text class="delete-linked-tip">取消勾选则只删除当前这一条记录。</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="secondary-button" disabled="{{deleteSubmitting}}" bindtap="handleCancelDelete">取消</button>
        <button class="primary-button delete-confirm-button" loading="{{deleteSubmitting}}" disabled="{{deleteSubmitting}}" bindtap="handleConfirmDelete">删除</button>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{formVisible}}" catchtap="handleCloseForm" catchtouchmove="noop">
    <view class="modal-panel" catchtap="noop">
      <view class="row modal-header">
        <text class="card-title">{{formTitle}}</text>
        <view class="close-button" bindtap="handleCloseForm">×</view>
      </view>

      <scroll-view class="modal-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view class="field-grid">
        <view class="form-field">
          <text class="field-label">消费分类</text>
          <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="handleCategoryChange">
            <view class="picker-field">{{categories[categoryIndex].name}}</view>
          </picker>
        </view>
        <view class="form-field" wx:if="{{showSubTypePicker}}">
          <text class="field-label">{{subTypeLabel}}</text>
          <picker mode="selector" range="{{subTypes}}" range-key="name" value="{{subTypeIndex}}" bindchange="handleSubTypeChange">
            <view class="picker-field">{{subTypes[subTypeIndex].name}}</view>
          </picker>
        </view>
      </view>

      <view class="field-grid">
        <view class="form-field">
          <text class="field-label"><text wx:if="{{formErrors.date}}" class="field-error-dot"></text>消费日期</text>
          <picker mode="date" value="{{formData.date}}" end="{{expenseDateEnd}}" bindchange="handleDateChange">
            <view class="picker-field {{formErrors.date ? 'field-invalid' : ''}}">{{formData.date || '请选择日期'}}</view>
          </picker>
          <text wx:if="{{formErrors.date}}" class="field-error-text">{{formErrors.date}}</text>
        </view>
        <view class="form-field">
          <text class="field-label">支付方式</text>
          <picker mode="selector" range="{{paymentMethods}}" value="{{paymentMethodIndex}}" bindchange="handlePaymentMethodChange">
            <view class="picker-field">{{paymentMethods[paymentMethodIndex]}}</view>
          </picker>
        </view>
      </view>

      <view wx:if="{{formData.category === 'meet'}}" class="form-section">
        <text class="section-title">{{subTypes[subTypeIndex].name}}场次</text>
        <text class="muted">见面日期用于匹配舞台场次，消费日期只记录这笔钱发生的日期。</text>
        <view class="form-field">
          <text class="field-label"><text wx:if="{{formErrors.itemName}}" class="field-error-dot"></text>{{subTypes[subTypeIndex].name}}名称</text>
          <input
            class="form-input {{formErrors.itemName ? 'field-invalid' : ''}}"
            value="{{formData.itemName}}"
            placeholder="搜索或填写演唱会名称"
            confirm-type="search"
            bindfocus="handleMeetNameFocus"
            bindblur="handleMeetNameBlur"
            bindinput="handleMeetNameInput"
          />
          <text wx:if="{{formErrors.itemName}}" class="field-error-text">{{formErrors.itemName}}</text>
          <view class="search-result-panel" wx:if="{{meetSearchFocused && searchResults.length}}">
            <view class="search-result" wx:for="{{searchResults}}" wx:key="id" data-id="{{item.id}}" bindtap="handleSelectSearchItem">
              <view>
                <text wx:for="{{item.highlightSegments}}" wx:for-item="segment" wx:key="index" class="{{segment.matched ? 'search-hit' : ''}}">{{segment.text}}</text>
              </view>
              <text class="muted">{{item.displayMeta}}</text>
            </view>
          </view>
        </view>
        <view class="form-field">
          <text class="field-label"><text wx:if="{{formErrors.stageDate}}" class="field-error-dot"></text>见面日期</text>
          <view class="date-option-row" wx:if="{{stageDateOptions.length}}">
            <view>
              <text
                class="date-option {{formData.stageDate === item.date ? 'date-option-active' : ''}}"
                wx:for="{{stageDateOptions}}"
                wx:key="stageId"
                data-index="{{index}}"
                bindtap="handleStageDateOptionTap"
              >{{item.date}}</text>
            </view>
            <picker mode="date" value="{{formData.stageDate}}" bindchange="handleMeetDateChange">
              <view class="date-option date-option-other">其他</view>
            </picker>
          </view>
          <picker wx:else mode="date" value="{{formData.stageDate}}" bindchange="handleMeetDateChange">
            <view class="picker-field {{formErrors.stageDate ? 'field-invalid' : ''}}">{{formData.stageDate || '请选择见面日期'}}</view>
          </picker>
          <text wx:if="{{formErrors.stageDate}}" class="field-error-text">{{formErrors.stageDate}}</text>
        </view>
        <view class="form-field">
          <text class="field-label">购买渠道</text>
          <picker mode="selector" range="{{purchaseChannels}}" range-key="name" value="{{purchaseChannelIndex}}" bindchange="handlePurchaseChannelChange">
            <view class="picker-field">{{purchaseChannels[purchaseChannelIndex].name}}</view>
          </picker>
        </view>
        <view class="form-field" wx:if="{{formData.purchaseChannel === 'official' && priceTierLabels.length}}">
          <text class="field-label"><text wx:if="{{formErrors.amount}}" class="field-error-dot"></text>金额档位</text>
          <picker mode="selector" range="{{priceTierLabels}}" value="{{priceTierIndex}}" bindchange="handlePriceTierChange">
            <view class="picker-field {{formErrors.amount ? 'field-invalid' : ''}}">{{priceTierLabels.length ? priceTierLabels[priceTierIndex] : '暂无档位'}}</view>
          </picker>
          <text wx:if="{{formErrors.amount}}" class="field-error-text">{{formErrors.amount}}</text>
        </view>
        <view class="form-field" wx:if="{{formData.purchaseChannel === 'other' || !priceTierLabels.length}}">
          <text class="field-label"><text wx:if="{{formErrors.amount}}" class="field-error-dot"></text>实际总金额</text>
          <input class="form-input {{formErrors.amount ? 'field-invalid' : ''}}" type="digit" inputmode="decimal" value="{{formData.amount}}" data-field="amount" placeholder="0.00" bindinput="handleFormInput" />
          <text wx:if="{{formErrors.amount}}" class="field-error-text">{{formErrors.amount}}</text>
        </view>
        <view class="field-grid">
          <view class="form-field warning-option-field">
            <text class="field-label"><text wx:if="{{formWarnings.city}}" class="field-warning-dot"></text>城市（选填）</text>
            <input class="form-input {{formWarnings.city ? 'field-warning' : ''}}" value="{{formData.city}}" data-field="city" placeholder="匹配场次后自动带入" bindinput="handleFormInput" bindfocus="handleWarningFieldFocus" bindblur="handleWarningFieldBlur" />
            <text wx:if="{{formWarnings.city}}" class="field-warning-text">{{formWarnings.city}}</text>
            <view class="search-result-panel warning-suggestion-panel" wx:if="{{focusedWarningField === 'city' && formWarnings.city && formData.expectedCity}}">
              <view class="search-result" data-field="city" bindtap="handleUseExpectedField">{{formData.expectedCity}}</view>
            </view>
          </view>
          <view class="form-field warning-option-field">
            <text class="field-label"><text wx:if="{{formWarnings.location}}" class="field-warning-dot"></text>地点（选填）</text>
            <input class="form-input {{formWarnings.location ? 'field-warning' : ''}}" value="{{formData.location}}" data-field="location" placeholder="匹配场次后自动带入" bindinput="handleFormInput" bindfocus="handleWarningFieldFocus" bindblur="handleWarningFieldBlur" />
            <text wx:if="{{formWarnings.location}}" class="field-warning-text">{{formWarnings.location}}</text>
            <view class="search-result-panel warning-suggestion-panel" wx:if="{{focusedWarningField === 'location' && formWarnings.location && formData.expectedLocation}}">
              <view class="search-result" data-field="location" bindtap="handleUseExpectedField">{{formData.expectedLocation}}</view>
            </view>
          </view>
          <view class="form-field">
            <text class="field-label">座位（选填）</text>
            <input class="form-input" value="{{formData.seat}}" data-field="seat" placeholder="例如：A区 12排 08座" bindinput="handleFormInput" />
          </view>
        </view>
        <view class="bundle-cost-panel">
          <view class="switch-row">
            <view>
              <text class="field-label">同时记录交通</text>
              <text class="muted">保存时会另外生成一条交通消费。</text>
            </view>
            <switch checked="{{formData.includeTransportCost}}" color="#f5c400" data-field="includeTransportCost" bindchange="handleBundleCostToggle" />
          </view>
          <view class="form-field" wx:if="{{formData.includeTransportCost}}">
            <text class="field-label"><text wx:if="{{formErrors.transportAmount}}" class="field-error-dot"></text>交通金额</text>
            <input class="form-input {{formErrors.transportAmount ? 'field-invalid' : ''}}" type="digit" inputmode="decimal" value="{{formData.transportAmount}}" data-field="transportAmount" placeholder="0.00" bindinput="handleFormInput" />
            <text wx:if="{{formErrors.transportAmount}}" class="field-error-text">{{formErrors.transportAmount}}</text>
          </view>

          <view class="switch-row">
            <view>
              <text class="field-label">同时记录住宿</text>
              <text class="muted">保存时会另外生成一条住宿消费。</text>
            </view>
            <switch checked="{{formData.includeAccommodationCost}}" color="#f5c400" data-field="includeAccommodationCost" bindchange="handleBundleCostToggle" />
          </view>
          <view class="form-field" wx:if="{{formData.includeAccommodationCost}}">
            <text class="field-label"><text wx:if="{{formErrors.accommodationAmount}}" class="field-error-dot"></text>住宿金额</text>
            <input class="form-input {{formErrors.accommodationAmount ? 'field-invalid' : ''}}" type="digit" inputmode="decimal" value="{{formData.accommodationAmount}}" data-field="accommodationAmount" placeholder="0.00" bindinput="handleFormInput" />
            <text wx:if="{{formErrors.accommodationAmount}}" class="field-error-text">{{formErrors.accommodationAmount}}</text>
          </view>
        </view>
      </view>

      <view wx:elif="{{formData.category === 'collection'}}" class="form-section">
        <text class="section-title">藏品信息</text>
        <input class="form-input" placeholder="搜索云端藏品名称" confirm-type="search" data-search-type="collection" bindinput="handleItemSearchInput" />
        <view class="search-result" wx:for="{{searchResults}}" wx:key="collectionId" data-id="{{item.collectionId}}" bindtap="handleSelectSearchItem">
          <view>
            <text wx:for="{{item.highlightSegments}}" wx:for-item="segment" wx:key="index" class="{{segment.matched ? 'search-hit' : ''}}">{{segment.text}}</text>
          </view>
          <view wx:if="{{item.detailText}}">
            <text wx:for="{{item.detailSegments}}" wx:for-item="segment" wx:key="index" class="muted {{segment.matched ? 'search-hit' : ''}}">{{segment.text}}</text>
          </view>
          <text class="muted">{{item.priceDisplayText}}</text>
        </view>
        <view class="matched-stage" wx:if="{{selectedCollectionMeta}}">
          已选：{{selectedCollectionMeta}}
        </view>
        <view class="form-field">
          <text class="field-label"><text wx:if="{{formErrors.itemName}}" class="field-error-dot"></text>藏品名称</text>
          <input class="form-input {{formErrors.itemName ? 'field-invalid' : ''}}" value="{{formData.itemName}}" data-field="itemName" placeholder="可手动填写，未选择候选则不联动藏品" bindinput="handleFormInput" />
          <text wx:if="{{formErrors.itemName}}" class="field-error-text">{{formErrors.itemName}}</text>
        </view>
        <view class="field-grid">
          <view class="form-field">
            <text class="field-label">购买渠道</text>
            <picker mode="selector" range="{{purchaseChannels}}" range-key="name" value="{{purchaseChannelIndex}}" bindchange="handlePurchaseChannelChange">
              <view class="picker-field">{{purchaseChannels[purchaseChannelIndex].name}}</view>
            </picker>
          </view>
          <view class="form-field" wx:if="{{formData.purchaseChannel === 'official'}}">
            <text class="field-label">价格记录方式</text>
            <picker mode="selector" range="{{pricingModes}}" range-key="name" value="{{pricingModeIndex}}" bindchange="handlePricingModeChange">
              <view class="picker-field">{{pricingModes[pricingModeIndex].name}}</view>
            </picker>
          </view>
          <view class="form-field" wx:else>
            <text class="field-label">价格记录方式</text>
            <view class="picker-field">直接填写总金额</view>
          </view>
        </view>
      </view>

      <view wx:else class="form-field">
        <text class="field-label"><text wx:if="{{formErrors.itemName}}" class="field-error-dot"></text>项目名称</text>
        <input class="form-input {{formErrors.itemName ? 'field-invalid' : ''}}" value="{{formData.itemName}}" data-field="itemName" placeholder="例如：酒店、车票、餐饮或其他消费" bindinput="handleFormInput" />
        <text wx:if="{{formErrors.itemName}}" class="field-error-text">{{formErrors.itemName}}</text>
      </view>

      <view class="field-grid" wx:if="{{formData.category === 'collection'}}">
        <view class="form-field">
          <text class="field-label"><text wx:if="{{formErrors.amount}}" class="field-error-dot"></text>{{formData.purchaseChannel === 'official' ? '金额 / 单价' : '实际总金额'}}</text>
          <input class="form-input {{formErrors.amount ? 'field-invalid' : ''}}" type="digit" inputmode="decimal" value="{{formData.amount}}" data-field="amount" placeholder="0.00" bindinput="handleFormInput" />
          <text wx:if="{{formErrors.amount}}" class="field-error-text">{{formErrors.amount}}</text>
        </view>
        <view class="form-field">
          <text class="field-label"><text wx:if="{{formErrors.quantity}}" class="field-error-dot"></text>数量</text>
          <input class="form-input {{formErrors.quantity ? 'field-invalid' : ''}}" type="number" inputmode="numeric" value="{{formData.quantity}}" data-field="quantity" placeholder="1" bindinput="handleFormInput" />
          <text wx:if="{{formErrors.quantity}}" class="field-error-text">{{formErrors.quantity}}</text>
        </view>
      </view>
      <view class="form-field" wx:elif="{{formData.category !== 'meet'}}">
        <text class="field-label"><text wx:if="{{formErrors.amount}}" class="field-error-dot"></text>实际总金额</text>
        <input class="form-input {{formErrors.amount ? 'field-invalid' : ''}}" type="digit" inputmode="decimal" value="{{formData.amount}}" data-field="amount" placeholder="0.00" bindinput="handleFormInput" />
        <text wx:if="{{formErrors.amount}}" class="field-error-text">{{formErrors.amount}}</text>
      </view>

      <view class="form-field">
        <text class="field-label">备注</text>
        <view class="selected-tag-row" wx:if="{{selectedRemarkTags.length}}">
          <view class="selected-tag" wx:for="{{selectedRemarkTags}}" wx:key="*this">
            <text>#{{item}}</text>
            <text class="selected-tag-close" data-tag="{{item}}" catchtap="handleRemoveRemarkTag">×</text>
          </view>
        </view>
        <input class="form-input" value="{{formRemarkText}}" data-field="remark" placeholder="选填，例如购买渠道、票务来源、追星感受" bindinput="handleFormInput" />
        <view class="quick-tag-row">
          <text
            class="quick-tag {{item.active ? 'quick-tag-active' : ''}}"
            wx:for="{{quickRemarkTags}}"
            wx:key="name"
            data-tag="{{item.name}}"
            bindtap="handleQuickRemarkTagTap"
          >#{{item.name}}</text>
        </view>
        <view class="custom-tag-row">
          <input class="custom-tag-input" value="{{customRemarkTag}}" placeholder="自定义标签" bindinput="handleCustomRemarkTagInput" />
          <button class="custom-tag-button" bindtap="handleAddCustomRemarkTag">添加</button>
        </view>
      </view>

      <view class="switch-row">
        <view>
          <text class="field-label">计入总消费统计</text>
          <text class="muted">关闭后不参与预算和累计消费。</text>
        </view>
        <switch checked="{{formData.includeInTotal}}" color="#f5c400" bindchange="handleIncludeChange" />
      </view>
      </scroll-view>

      <view class="modal-actions" catchtouchmove="noop">
        <button class="secondary-button" disabled="{{formSubmitting}}" bindtap="handleCloseForm">取消</button>
        <button class="primary-button" loading="{{formSubmitting}}" disabled="{{formSubmitting}}" bindtap="handleSubmitForm">保存</button>
      </view>
    </view>
  </view>
</view>
