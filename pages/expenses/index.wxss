.card .muted {
  display: block;
  margin-top: 8rpx;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.search-input,
.form-input,
.picker-field {
  width: 100%;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #eadca8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #2a2418;
  font-size: 26rpx;
  line-height: 72rpx;
}

.toolbar-actions,
.item-actions,
.modal-actions {
  display: flex;
  gap: 16rpx;
}

.compact-button {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  margin: 0;
  font-size: 25rpx;
  line-height: 1;
  text-align: center;
}

.expense-meta {
  align-items: flex-end;
  margin-top: 4rpx;
}

.amount {
  color: #a06a00;
  font-size: 38rpx;
  font-weight: 700;
}

.item-actions {
  margin-top: 22rpx;
}

.danger-button {
  color: #9c4f00;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(32, 26, 24, 0.42);
}

.modal-panel {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-height: 88vh;
  padding: 0 30rpx 30rpx;
  overflow: hidden;
  border-radius: 20rpx 20rpx 16rpx 16rpx;
  background: #fffef9;
}

.modal-header {
  z-index: 2;
  margin: 0 -30rpx 18rpx;
  padding: 28rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f1e4b6;
  background: #fffef9;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
  max-height: calc(88vh - 230rpx);
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.close-button {
  display: flex;
  flex: 0 0 64rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-width: 64rpx;
  max-width: 64rpx;
  height: 64rpx;
  min-height: 64rpx;
  max-height: 64rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: #fff2bf;
  color: #111111;
  font-size: 40rpx;
  line-height: 1;
  text-align: center;
}

.close-button::after {
  border: 0;
}

.form-field {
  position: relative;
  margin-bottom: 20rpx;
}

.form-section {
  margin: 8rpx 0 24rpx;
  padding: 22rpx;
  border: 1rpx solid #efe0a8;
  border-radius: 14rpx;
  background: #fffefe;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #2d2718;
  font-size: 27rpx;
  font-weight: 700;
}

.matched-stage {
  min-height: 72rpx;
  margin: 16rpx 0 20rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #eadca8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #2d2718;
  font-size: 26rpx;
  line-height: 1.4;
}

.unmatched-stage {
  color: #9c4f00;
  background: #fff7da;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #4d4328;
  font-size: 25rpx;
  font-weight: 600;
}

.field-error-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #d93025;
  vertical-align: 4rpx;
}

.field-warning-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #d6a400;
  vertical-align: 4rpx;
}

.field-invalid {
  border-color: #d93025 !important;
  background: #fff8f7 !important;
}

.field-warning {
  border-color: #d6a400 !important;
  background: #fffdf4 !important;
}

.field-error-text {
  display: block;
  margin-top: 8rpx;
  color: #d93025;
  font-size: 22rpx;
  line-height: 1.35;
}

.field-hint {
  display: block;
  margin-top: 8rpx;
  color: #8b7a55;
  font-size: 22rpx;
  line-height: 1.35;
}

.field-warning-text {
  display: block;
  margin-top: 8rpx;
  color: #9c6a00;
  font-size: 22rpx;
  line-height: 1.35;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.bundle-cost-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx dashed #eadca8;
  border-radius: 12rpx;
  background: #fffdf4;
}

.fee-single {
  margin-top: 18rpx;
}

.search-result {
  min-height: 64rpx;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f2e5b4;
  background: #ffffff;
  color: #2d2718;
  font-size: 25rpx;
  line-height: 1.4;
}

.search-result:last-child {
  border-bottom: 0;
}

.search-result-panel {
  margin-top: 10rpx;
  overflow: hidden;
  border: 1rpx solid #efe0a8;
  border-radius: 12rpx;
  background: #ffffff;
}

.warning-suggestion-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 126rpx;
  z-index: 8;
  margin-top: 0;
  border-color: #f0d878;
  background: #fffdf4;
  box-shadow: 0 10rpx 24rpx rgba(118, 88, 0, 0.14);
}

.warning-option-field .field-warning-text {
  position: absolute;
  left: 0;
  right: 0;
  top: 126rpx;
  z-index: 7;
  margin-top: 0;
  padding: 10rpx 14rpx;
  border: 1rpx solid #f0d878;
  border-radius: 10rpx;
  background: #fffdf4;
  box-shadow: 0 8rpx 20rpx rgba(118, 88, 0, 0.1);
}

.search-hit {
  color: #d12b2b;
  font-weight: 800;
}

.date-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.date-option-row > view {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.date-option {
  display: inline-flex;
  min-height: 64rpx;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border: 1rpx solid #eadca8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #5f543e;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.date-option-active {
  border-color: #d6a400;
  background: #fff2bf;
  color: #8a6400;
}

.date-option-other {
  background: #fffdf4;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.image-item,
.image-add {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  border: 1rpx solid #eadca8;
  border-radius: 12rpx;
  background: #ffffff;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(32, 26, 24, 0.68);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 38rpx;
}

.image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a06a00;
  font-size: 56rpx;
  font-weight: 300;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin: 6rpx 0 24rpx;
  padding: 18rpx 0;
}

.switch-row .muted {
  margin-top: 4rpx;
}

.modal-actions button {
  flex: 1;
}

.modal-actions {
  flex-shrink: 0;
  margin-top: 14rpx;
  padding-top: 16rpx;
  background: #fffef9;
}

.expense-page {
  padding-top: 0;
  background: #fff9ec;
}

.expense-page > .page-title,
.expense-page > .page-subtitle,
.legacy-top-card,
.legacy-toolbar {
  display: none;
}

.expense-hero {
  margin: -24rpx -24rpx 0;
  padding: 42rpx 30rpx 30rpx;
  background: #fff4c7;
  color: #2a2418;
}

.hero-title {
  display: block;
  color: #2a2418;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #827866;
  font-size: 24rpx;
  line-height: 1.5;
}

.category-tabs {
  margin: 0 -24rpx;
  padding: 12rpx 24rpx 18rpx;
  white-space: nowrap;
  background: #fff4c7;
}

.category-tab {
  display: inline-flex;
  position: relative;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 62rpx;
  margin-right: 18rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #746a59;
  font-size: 27rpx;
  font-weight: 700;
}

.category-tab-active {
  background: #ffffff;
  color: #a06a00;
  box-shadow: 0 8rpx 18rpx rgba(126, 86, 0, 0.08);
}

.category-tab-active::after {
  position: absolute;
  right: 18rpx;
  bottom: 0;
  left: 18rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #e7b900;
  content: '';
}

.stats-card {
  margin: 22rpx 0 18rpx;
  padding: 24rpx 18rpx 22rpx;
  border: 1rpx solid #efe0a8;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(126, 86, 0, 0.08);
}

.amount-summary {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 8rpx 20rpx;
  border-bottom: 1rpx solid #f3e8bd;
}

.amount-summary-label {
  color: #827866;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.amount-summary-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  max-width: 100%;
  margin-top: 8rpx;
  color: #b48a00;
  line-height: 1;
  white-space: nowrap;
}

.amount-symbol {
  margin-right: 6rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.amount-number {
  font-size: 48rpx;
  font-weight: 900;
}

.count-summary-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  padding-top: 20rpx;
}

.stat-item {
  min-width: 0;
  padding: 4rpx 0;
  text-align: center;
}

.stat-value {
  display: block;
  color: #2a2418;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.15;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #827866;
  font-size: 22rpx;
  line-height: 1.25;
}

.stat-item-active .stat-value,
.stat-item-active .stat-label {
  color: #b48a00;
}

.summary-hint {
  margin: -6rpx 0 18rpx;
  color: #827866;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.filter-card {
  margin-bottom: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #efe0a8;
  border-radius: 18rpx;
  background: #ffffff;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff2bf;
  color: #2a2418;
  font-size: 25rpx;
  font-weight: 700;
}

.filter-chip-label {
  margin-right: 16rpx;
  color: #827866;
}

.filter-chip-value {
  color: #8a6400;
}

.sort-picker {
  min-height: 64rpx;
  padding: 0 18rpx;
  border: 1rpx solid #eadca8;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5f543e;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 64rpx;
  white-space: nowrap;
}

.extra-switch {
  display: flex;
  flex: 0 1 auto;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  color: #5f543e;
  font-size: 23rpx;
  line-height: 1.35;
  text-align: left;
  white-space: nowrap;
}

.filter-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.filter-switch-row .extra-switch:first-child {
  justify-content: flex-start;
}

.filter-switch-row .extra-switch:last-child {
  justify-content: flex-end;
}

.add-expense-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 430rpx;
  height: 82rpx;
  margin: 24rpx auto 26rpx;
  border-radius: 12rpx;
  background: #D6A400;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(214, 164, 0, 0.24);
}

.expense-card {
  margin-bottom: 18rpx;
  padding: 24rpx 24rpx 22rpx;
  border: 1rpx solid #efe0a8;
  border-radius: 16rpx;
  box-shadow: none;
}

.expense-card > .row,
.expense-card > .muted,
.expense-card > .item-actions {
  display: none;
}

.expense-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.type-tag {
  display: inline-flex;
  flex: 1 1 260rpx;
  max-width: 420rpx;
  min-width: 0;
  min-height: 44rpx;
  align-items: center;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #fff2bf;
  color: #7a5a00;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.bundle-tag {
  display: inline-flex;
  min-height: 44rpx;
  align-items: center;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: #f7efe0;
  color: #8a6400;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.bundle-link-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 8rpx;
}

.bundle-link-note {
  display: inline-flex;
  max-width: 100%;
  min-height: 38rpx;
  align-items: center;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #fff8dc;
  color: #8a6400;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.expense-card .amount {
  flex-shrink: 0;
  color: #a06a00;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.amount-stack {
  display: flex;
  flex: 1 1 220rpx;
  min-width: 0;
  flex-direction: column;
  align-items: flex-end;
  max-width: 100%;
}

.display-amount {
  display: block;
  max-width: 100%;
  color: #a06a00;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow-wrap: anywhere;
  text-align: right;
  word-break: break-all;
}

.expense-title {
  display: block;
  color: #2a2418;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.expense-meta-new,
.expense-note {
  display: block;
  max-width: 100%;
  margin-top: 10rpx;
  color: #827866;
  font-size: 25rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.expense-note-wrap {
  margin-top: 10rpx;
  max-width: 100%;
}

.expense-note-wrap .expense-note {
  margin-top: 0;
}

.expense-note-paragraph {
  display: block;
  max-width: 100%;
}

.expense-note-paragraph + .expense-note-paragraph {
  margin-top: 12rpx;
}

.remark-toggle {
  display: inline-block;
  margin-top: 8rpx;
  color: #a06a00;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.remark-tag-row,
.quick-tag-row,
.selected-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.remark-tag-row {
  margin-top: 10rpx;
}

.quick-tag-row {
  margin-top: 12rpx;
}

.selected-tag-row {
  margin-bottom: 12rpx;
}

.remark-tag,
.quick-tag,
.selected-tag {
  display: inline-flex;
  min-height: 40rpx;
  align-items: center;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #fff8dc;
  color: #8a6400;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.quick-tag {
  min-height: 48rpx;
  padding: 0 16rpx;
  border: 1rpx solid #eadca8;
  background: #fffef9;
  color: #6d5b2b;
  font-size: 23rpx;
  line-height: 48rpx;
}

.quick-tag-active {
  border-color: #d6a400;
  background: #fff2bf;
  color: #8a6400;
}

.selected-tag {
  min-height: 52rpx;
  gap: 8rpx;
  padding: 0 10rpx 0 16rpx;
  border: 1rpx solid #d6a400;
  background: #fff2bf;
  color: #7a5a00;
  font-size: 24rpx;
  line-height: 52rpx;
}

.selected-tag-close {
  display: inline-flex;
  width: 34rpx;
  height: 34rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(138, 100, 0, 0.14);
  color: #8a6400;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.custom-tag-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.remark-input-wrap {
  position: relative;
  width: 100%;
  min-height: 88rpx;
  border: 1rpx solid #eadca8;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.remark-textarea {
  width: 100%;
  min-height: 88rpx;
  max-height: 260rpx;
  padding: 18rpx 128rpx 18rpx 22rpx;
  color: #2a2418;
  font-size: 26rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.remark-counter {
  position: absolute;
  right: 18rpx;
  bottom: 16rpx;
  min-width: 96rpx;
  color: #9c8c65;
  font-size: 22rpx;
  line-height: 1.2;
  text-align: right;
  pointer-events: none;
}

.custom-tag-input-wrap {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 58rpx;
}

.custom-tag-input {
  width: 100%;
  height: 58rpx;
  padding: 0 18rpx;
  padding-right: 86rpx;
  border: 1rpx solid #eadca8;
  border-radius: 10rpx;
  background: #fffef9;
  color: #2d2718;
  font-size: 24rpx;
  box-sizing: border-box;
}

.custom-tag-counter {
  position: absolute;
  right: 14rpx;
  top: 50%;
  color: #9c8c65;
  font-size: 20rpx;
  line-height: 1.2;
  pointer-events: none;
  transform: translateY(-50%);
}

.custom-tag-button {
  flex: 0 0 120rpx;
  min-width: 120rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 10rpx;
  background: #fff2bf;
  color: #8a6400;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.delete-dialog {
  width: 100%;
  padding: 0 30rpx 30rpx;
  border-radius: 20rpx 20rpx 16rpx 16rpx;
  background: #fffef9;
}

.delete-dialog-header {
  margin: 0 -30rpx;
  padding: 30rpx;
  border-bottom: 1rpx solid #f1e4b6;
}

.delete-dialog-body {
  padding: 24rpx 0 10rpx;
}

.delete-warning,
.delete-target,
.delete-linked-tip {
  display: block;
  color: #5f543e;
  font-size: 26rpx;
  line-height: 1.5;
}

.delete-warning {
  color: #8f3d1f;
  font-weight: 700;
}

.delete-target {
  margin-top: 12rpx;
}

.delete-linked-box {
  margin-top: 20rpx;
  padding: 18rpx;
  border: 1rpx solid #eadca8;
  border-radius: 12rpx;
  background: #fffdf4;
}

.delete-check-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #2d2718;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
}

.delete-linked-tip {
  margin-top: 10rpx;
  color: #827866;
  font-size: 23rpx;
}

.delete-confirm-button {
  background: #9c4f00;
}

.fee-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.fee-tag {
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #fff7da;
  color: #8a6400;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.expense-actions-new {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.edit-button,
.delete-button {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  margin: 0;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.edit-button {
  background: #eeeeec;
  color: #1f1f1f;
}

.delete-button {
  background: #fff0d2;
  color: #9c4f00;
}

.expense-page .primary-button {
  background: #D6A400;
  color: #ffffff;
}

.expense-page .secondary-button {
  border-color: #e6d7a8;
  color: #3a3324;
}

.expense-page .close-button {
  background: #fff4c2;
  color: #111111;
}

.expense-page .image-add {
  color: #b48a00;
}
