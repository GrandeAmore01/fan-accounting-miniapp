.card .muted {
  display: block;
  margin-top: 8rpx;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.search-input,
.form-input,
.picker-field {
  width: 100%;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #eadbd5;
  border-radius: 12rpx;
  background: #ffffff;
  color: #2d2928;
  font-size: 26rpx;
  line-height: 72rpx;
}

.toolbar-actions,
.item-actions,
.modal-actions {
  display: flex;
  gap: 16rpx;
}

.compact-button {
  flex: 1;
  height: 64rpx;
  margin: 0;
  font-size: 25rpx;
  line-height: 64rpx;
}

.expense-meta {
  align-items: flex-end;
  margin-top: 4rpx;
}

.amount {
  color: #c84d69;
  font-size: 38rpx;
  font-weight: 700;
}

.item-actions {
  margin-top: 22rpx;
}

.danger-button {
  color: #a13f3f;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(32, 26, 24, 0.42);
}

.modal-panel {
  width: 100%;
  max-height: 88vh;
  padding: 30rpx;
  overflow-y: auto;
  border-radius: 20rpx 20rpx 16rpx 16rpx;
  background: #fffaf7;
}

.modal-header {
  margin-bottom: 18rpx;
}

.close-button {
  width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #f3e4df;
  color: #7d5458;
  font-size: 40rpx;
  line-height: 60rpx;
}

.form-field {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #4d4542;
  font-size: 25rpx;
  font-weight: 600;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin: 6rpx 0 24rpx;
  padding: 18rpx 0;
}

.switch-row .muted {
  margin-top: 4rpx;
}

.modal-actions button {
  flex: 1;
}
